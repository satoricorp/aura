{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": {
    "builtin": true,
    "node": true
  },
  "ignorePatterns": ["coverage/**", "dist/**", "node_modules/**"],
  "options": {
    "denyWarnings": true
  },
  "overrides": [
    {
      "files": ["tests/**/*.ts"],
      "globals": {
        "afterAll": "readonly",
        "afterEach": "readonly",
        "beforeAll": "readonly",
        "beforeEach": "readonly",
        "describe": "readonly",
        "expect": "readonly",
        "it": "readonly",
        "test": "readonly"
      }
    }
  ]
}
